{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClaudeCopilot",
  "version": "0.2.1",
  "identifier": "cool.cnb.weixiao.claude-copilot-desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Claude Copilot",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://cnb.cool/weixiao.space/claude-copilot/-/git/raw/main/.updater/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxQjQxMzIwQ0E4RTRGNDUKUldSRlQ0N0tJQk8wa1VvV1lUUkVWQ0pIUmNtaUduSlVTMVA0NUF3WjBLaVBIWmF3NkRQRUJRamUK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
